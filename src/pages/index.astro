---
import "../styles/global.css";
import { pricing } from "../data/pricing";

const businessName = "The Tech Doctor";
const euro = (amount) => `${String.fromCharCode(8364)}${amount}`;
const faviconHref = `${import.meta.env.BASE_URL}favicon.ico`;

const overviewCards = [
  {
    title: "Duidelijke hulp",
    text: "U krijgt eerst een heldere uitleg, daarna pas een voorstel. Geen technisch verhaal waar u niets aan hebt."
  },
  {
    title: "Aan huis of in atelier",
    text: "Voor eenvoudige problemen komen we aan huis. Voor grondiger werk in atelier is de aanpak meestal sneller en voordeliger."
  },
  {
    title: "Prijs vooraf",
    text: "We werken met vaste prijzen waar dat kan en met een duidelijk uurtarief voor complexe dossiers."
  }
];

const standardServices = [
  "Diagnose en analyse aan huis",
  "Simpele PC opschoning (1-2 uur werk)",
  "Diepe PC opschoning (tot 3 uur werk)"
];

const advancedServices = [
  "Dataherstel van pc's en beschadigde systemen",
  "Virus- en malwareverwijdering",
  "Complexe fouten, opstartproblemen en problemen met externe schijven"
];

const processSteps = [
  {
    step: "1",
    title: "U legt het probleem uit",
    text: "Telefonisch, via mail of bij een bezoek. We luisteren eerst en houden het simpel. Dit eerste contact is gratis."
  },
  {
    step: "2",
    title: "We kiezen de juiste aanpak",
    text: "Aan huis voor snelle hulp, of in atelier als het probleem meer tijd en testen vraagt. Ook dit advies is gratis."
  },
  {
    step: "3",
    title: "U krijgt een prijsinschatting",
    text: "Voor standaardwerk is die vast. Voor complexe gevallen spreken we duidelijk af wat het uurtarief is. De diagnose aan huis kan gratis zijn als u daarna klant wordt."
  },
  {
    step: "4",
    title: "We lossen het op",
    text: "Zodra extra werk of kosten nodig zijn, vragen we eerst uw toestemming."
  }
];

const trustPoints = [
  "Ervaring in cybersecurity en praktische probleemoplossing",
  "Geschikt voor klanten die niet technisch zijn",
  "Duidelijke communicatie zonder onnodig jargon",
  "Transparante prijzen en toestemming bij extra kosten"
];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{businessName} | Computerhulp, dataherstel en malwareverwijdering</title>
    <meta
      name="description"
      content="Heldere computerhulp in Lede en omgeving. Diagnose, opschonen, herinstallatie, dataherstel en malwareverwijdering met duidelijke prijzen en eenvoudige uitleg."
    />
    <link rel="icon" type="image/x-icon" href={faviconHref} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Spring naar inhoud</a>

    <header class="site-header">
      <div class="container nav-wrap">
        <a href="#hero" class="logo">{businessName}</a>
        <button class="nav-toggle" aria-label="Open menu" aria-expanded="false">
          Menu
        </button>
        <nav class="site-nav" aria-label="Hoofdnavigatie">
          <a href="#services">Diensten</a>
          <a href="#process">Werkwijze</a>
          <a href="#pricing">Prijzen</a>
          <a href="#about">Over ons</a>
          <a href="#contact">Contact</a>
        </nav>
        <a class="nav-cta" href="tel:+32488221025">Bel nu</a>
      </div>
    </header>

    <main id="main-content">
      <section id="hero" class="hero">
        <div class="container hero-simple">
          <p class="eyebrow">Computerhulp in klare taal</p>
          <h1>Snelle, duidelijke hulp voor computers en dataherstel</h1>
          <p class="hero-copy">
            Voor trage computers, virussen, herinstallaties en dataherstel. U krijgt altijd een begrijpelijke uitleg, een logische aanpak en een prijsinschatting vooraf.
          </p>
          <div class="hero-actions">
            <a href="#pricing" class="button">Bekijk prijzen</a>
            <a href="#contact" class="button button-secondary">Neem contact op</a>
          </div>
          <div class="hero-meta" aria-label="Belangrijkste voordelen">
            <p>Duidelijke prijs vooraf</p>
            <p>Aan huis of in atelier</p>
            <p>Ook voor niet-technische klanten</p>
            <p>Transportkost bij verplaatsing: {euro(pricing.pickupDropoffFee)}</p>
          </div>
        </div>
      </section>

      <section class="section section-overview">
        <div class="container">
          <div class="section-heading">
            <p class="section-kicker">Ons kenmerk</p>
            <h2>Dit mag u van ons verwachten</h2>
          </div>
          <div class="overview-grid overview-grid-minimal">
            {
              overviewCards.map((card) => (
                <article class="overview-card">
                  <h3>{card.title}</h3>
                  <p>{card.text}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="services" class="section">
        <div class="container">
          <div class="section-heading">
            <p class="section-kicker">Onze diensten</p>
            <h2>Hulp op maat, helder uitgelegd</h2>
            <p class="section-lead">
              We houden de keuze eenvoudig. Standaard werk heeft een vaste prijs. Geavanceerde hulp is grondiger en daarom <strong>uitsluitend beschikbaar in atelier</strong>.
            </p>
          </div>

          <div class="service-groups">
            <article class="service-group">
              <p class="group-tag">Vaste prijs</p>
              <h3>Standaard diensten</h3>
              <ul class="check-list">
                {standardServices.map((item) => <li>{item}</li>)}
              </ul>
              <p class="group-note">
                Ideaal voor duidelijke, afgebakende problemen waarbij de oplossing vooraf goed in te schatten is.
              </p>
            </article>

            <article class="service-group service-group-emphasis">
              <p class="group-tag">Alleen in atelier</p>
              <h3>Geavanceerde en hersteldiensten</h3>
              <ul class="check-list">
                {advancedServices.map((item) => <li>{item}</li>)}
              </ul>
              <p class="group-note">
                Deze opdrachten vragen meer tijd, testen of gespecialiseerde tools. Daarom voeren we ze niet aan huis uit.
              </p>
            </article>

            <article class="service-group">
              <p class="group-tag">Aanbevolen</p>
              <h3>Waarom werken in atelier vaak beter is</h3>
              <ul class="check-list">
                <li>Meer tijd voor grondige analyse</li>
                <li>Snellere afhandeling in complexe dossiers</li>
                <li>Geen wachttijd bij u thuis</li>
                <li>Efficientere werkwijze en vaak lagere kost</li>
              </ul>
              <p class="group-note">
                Voor ingewikkelde problemen is dit meestal de snelste en meest betrouwbare aanpak.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="process" class="section section-alt">
        <div class="container">
          <div class="section-heading">
            <p class="section-kicker">Werkwijze</p>
            <h2>Zo houden we het duidelijk en rustig</h2>
            <p class="section-lead">
              Het eerste contact en het advies over de juiste aanpak zijn gratis. Ook de diagnose aan huis kan gratis zijn wanneer u daarna klant wordt en een dienst laat uitvoeren.
            </p>
          </div>
          <div class="process-grid">
            {
              processSteps.map((item) => (
                <article class="process-card">
                  <p class="process-step">{item.step}</p>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="pricing" class="section section-accent">
        <div class="container">
          <div class="section-heading">
            <p class="section-kicker">Prijzen</p>
            <h2>Duidelijke prijzen zonder verrassingen</h2>
            <p class="section-lead">
              We tonen eerst de eenmalige vaste prijzen, daarna de diensten op uurtarief. Zo ziet u meteen waar u aan toe bent.
            </p>
            <p class="promo-note">
              Promotie: als opstartende zaak geven we de eerste klanten een extra korting.
            </p>
          </div>

          <div class="pricing-grid">
            <article class="price-card">
              <h3>Diagnose aan huis</h3>
              <p class="price-highlight">{euro(pricing.diagnosisHome)}</p>
              <p class="price-subtitle">Voor ongeveer 30 minuten analyse en uitleg</p>
              <ul>
                <li>We stellen het probleem vast</li>
                <li>U krijgt uitleg in begrijpelijke taal</li>
                <li>U krijgt vooraf een prijsinschatting</li>
                <li>Gratis als u daarna een dienst laat uitvoeren</li>
              </ul>
            </article>

            <article class="price-card">
              <h3>Simpele PC opschoning</h3>
              <p class="price-subtitle">Eenmalige vaste prijs</p>
              <p class="price-subtitle">Richttijd: 1-2 uur werk</p>
              <div class="price-options">
                <div class="price-option">
                  <p class="price-option-label">Aan huis</p>
                  <p class="price-line">{euro(pricing.simplePcCleanupHome)}</p>
                </div>
                <div class="price-option">
                  <p class="price-option-label">In atelier</p>
                  <p class="price-line">{euro(pricing.simplePcCleanupPickup)}</p>
                </div>
              </div>
              <ul>
                <li>Tijdelijke bestanden en overbodige programma's opruimen</li>
                <li>Betere prestaties en sneller opstarten</li>
                <li>Basiscontrole van het systeem</li>
              </ul>
            </article>

            <article class="price-card price-card-most-chosen">
              <h3>Diepe PC opschoning</h3>
              <p class="price-subtitle">Eenmalige vaste prijs</p>
              <p class="price-subtitle">Richttijd: tot 3 uur werk</p>
              <p class="price-subtitle"><strong>Meest gekozen optie bij trage of problematische pc's</strong></p>
              <div class="price-options">
                <div class="price-option">
                  <p class="price-option-label">Aan huis</p>
                  <p class="price-line">{euro(pricing.deepPcCleanupHome)}</p>
                </div>
                <div class="price-option">
                  <p class="price-option-label">In atelier</p>
                  <p class="price-line">{euro(pricing.deepPcCleanupPickup)}</p>
                </div>
              </div>
              <ul>
                <li>Grondige opschoning en uitgebreid systeemonderhoud</li>
                <li>Diepere controle op prestaties en stabiliteit</li>
                <li>Extra tijd voor hardnekkige vertragingen en rommelsoftware</li>
                <li>Fysieke reiniging van de pc (stof en vuil verwijderen) om oververhitting te helpen voorkomen</li>
                <li>Ideaal voor systemen die al langer problemen vertonen</li>
                <li>Is er na 3 uur extra tijd nodig, dan nemen we eerst contact op en schakelen we over op {euro(pricing.advancedHourly)}/uur</li>
              </ul>
            </article>

            <div class="pricing-divider" aria-hidden="true"></div>

            <article class="price-card">
              <h3>Geavanceerde diensten</h3>
              <p class="price-line">{euro(pricing.advancedHourly)}/uur</p>
              <p class="price-subtitle">Minimum {pricing.advancedMinimumHours} uur, alleen in atelier</p>
              <ul>
                <li>Dataherstel</li>
                <li>Virus- en malwareverwijdering</li>
                <li>Complexe fouten en opstartproblemen</li>
                <li>Toestemming bij hogere kosten</li>
              </ul>
            </article>

            <article class="price-card">
              <h3>Transportkost</h3>
              <p class="price-line">{euro(pricing.pickupDropoffFee)} per verplaatsing</p>
              <p class="price-subtitle">Wordt altijd aangerekend als we ons moeten verplaatsen</p>
              <p class="price-subtitle">Wordt kwijtgescholden vanaf {euro(pricing.pickupDropoffFreeFrom)}</p>
              <ul>
                <li>Geldt voor aan huis afspraken en andere verplaatsingen</li>
                <li>Niet van toepassing wanneer de klant zelf langskomt</li>
              </ul>
            </article>

            <article class="price-card">
              <h3>Belangrijke info</h3>
              <ul>
                <li>Dataherstel kan nooit volledig gegarandeerd worden</li>
                <li>Bij bijkomende problemen kan de prijsinschatting wijzigen, maar nooit zonder eerst contact met u op te nemen</li>
                <li>Wachtwoorden of toegang kunnen nodig zijn</li>
                <li>We communiceren altijd vooraf als er iets verandert</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <section id="referral" class="section">
        <div class="container">
          <div class="section-heading">
            <p class="section-kicker">Vriendenkorting</p>
            <h2>Doorverwijzen loont</h2>
            <p class="section-lead">
              Verwijst u nieuwe klanten door? Dan krijgt u korting op uw volgende service.
            </p>
          </div>

          <article class="price-card referral-card">
            <ul>
              <li>1 doorverwezen klant: <strong>10% korting</strong> op uw volgende service</li>
              <li>2 doorverwezen klanten: <strong>15% korting</strong> op uw volgende service</li>
              <li>3 of meer doorverwezen klanten: <strong>20% korting</strong> op uw volgende service</li>
            </ul>
          </article>
        </div>
      </section>

      <section id="about" class="section">
        <div class="container about-grid">
          <div>
            <div class="section-heading section-heading-left">
              <p class="section-kicker">Over ons</p>
              <h2>Professioneel, maar zonder ingewikkeld te doen</h2>
            </div>
            <p class="section-lead section-lead-left">
              Bij {businessName} combineren we opleiding in informaticabeheer en Computer & Cybercrime met jaren praktijkervaring in security en technische probleemoplossing.
            </p>
            <p class="section-copy">
              Dat betekent voor u geen moeilijk jargon, maar een aanpak die tegelijk grondig en geruststellend is. U moet vooral begrijpen wat er aan de hand is, wat we gaan doen en wat het zal kosten.
            </p>
          </div>

          <div class="trust-panel">
            <h3>Waarom klanten voor ons kiezen</h3>
            <ul class="check-list">
              {trustPoints.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <section id="contact" class="section section-contact">
        <div class="container contact-grid">
          <div>
            <div class="section-heading section-heading-left">
              <p class="section-kicker">Contact</p>
              <h2>Vlot bereikbaar voor vragen en afspraken</h2>
            </div>
            <p class="section-lead section-lead-left">
              Twijfelt u welke dienst u nodig hebt? Neem gerust contact op. We helpen u graag kiezen tussen hulp aan huis en in atelier.
            </p>
          </div>

          <div class="contact-card">
            <p><strong>Email</strong><br /><a href="mailto:robin@de-wolf.eu">robin@de-wolf.eu</a></p>
            <p><strong>Telefoon</strong><br /><a href="tel:+32488221025">+32 488 22 10 25</a></p>
            <p><strong>Adres</strong><br />Spoorstraat 119, 9340 Lede</p>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-wrap">
        <p>&copy; {new Date().getFullYear()} {businessName}</p>
        <p>Duidelijke hulp voor al uw IT problemen.</p>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector(".nav-toggle");
      const nav = document.querySelector(".site-nav");
      if (toggle && nav) {
        toggle.addEventListener("click", () => {
          const open = nav.classList.toggle("open");
          toggle.setAttribute("aria-expanded", String(open));
        });
      }
    </script>
  </body>
</html>
